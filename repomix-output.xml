  async searchUsers(req: AuthRequest, res: Response) {
    try {
      const { query } = req.query; // e.g. /search?query=rahul

      const users = await prisma.user.findMany({
        where: {
          OR: [
            { username: { contains: query as string, mode: 'insensitive' } },
            { displayName: { contains: query as string, mode: 'insensitive' } }
          ],
          NOT: { id: req.user?.id } // Khud ko search mein mat dikhao
        },
        select: {
          id: true,
          username: true,
          displayName: true,
          avatarUrl: true
        },
        take: 10
      });

      res.status(200).json({ success: true, data: users });
    } catch (error: any) {
      res.status(500).json({ success: false, message: error.message });
    }
