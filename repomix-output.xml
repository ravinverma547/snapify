      if (!prompt) {
        return res.status(400).json({ success: false, message: "Kuch toh pucho bhai!" });
      }

      const aiResponse = await aiService.getAIResponse(prompt);

      res.status(200).json({
        success: true,
        reply: aiResponse
      });
    } catch (error: any) {
      res.status(500).json({ success: false, message: error.message });
    }
  }
}
